# Cookie signing/encryption key (hex, 128 chars without 0x prefix)
# Generate: openssl rand -hex 64
COOKIE_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple OAuth
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_AUTH_KEY_PEM=

# JWT ES256 keypair (for signing auth tokens)
# Generate: openssl ecparam -genkey -noout -name prime256v1 | openssl pkcs8 -topk8 -nocrypt -out jwt_es256.pem
JWT_EC_PEM=
# Derive: openssl ec -in jwt_es256.pem -pubout -out jwt_pub_es256.pem
JWT_PUB_EC_PEM=

# JWT Ed25519 keypair (for signing client secrets)
# Generate: openssl genpkey -algorithm ed25519 -out jwt_client_ed.pem
CLIENT_JWT_ED_PEM=
# Derive: openssl pkey -in jwt_client_ed.pem -pubout -out jwt_client_pub_ed.pem
CLIENT_JWT_PUB_ED_PEM=

# ── Dragonfly/Redis TLS (production KV store) ───────────────────────────────

DRAGONFLY_REDIS_STORE_PASSWORD=
DRAGONFLY_REDIS_STORE_HOSTS=
DRAGONFLY_REDIS_STORE_CA_CERT=
DRAGONFLY_REDIS_STORE_CLIENT_CERT=
DRAGONFLY_REDIS_STORE_CLIENT_KEY=

# ── Local deployment (task_runner) ──────────────────────────────────────────
# Used by: cargo test -p task_runner -- --ignored deploy --nocapture

HETZNER_HOSTS="157.90.129.188 138.201.120.111"
IMAGE_TAG=latest
GHCR_USERNAME=
# Create at: https://github.com/settings/tokens/new?scopes=write:packages
GHCR_TOKEN=
